#include<stdio.h>
void sort(int[], int);
void binary_search(int[], int, int);
void main()
{
	int i, a[50], n, x;
	printf("Enter value of n:");
	scanf("%d", &n);
	printf("Enter elements:");
	for(i=0; i<n; i++)
	{
		scanf("%d", &a[i]);
	}
	sort(a, n);
	printf("Enter number to search:");
	scanf("%d", &x);

	binary_search(a, n, x);
}
void sort(int list[], int n)
{
	int i, j;
	for(i=0; i<n; i++)
	{
		for(j=i+1; j<=n-1; j++)
		{
			if(list[i]>list[j])
			{
				int temp=list[i];
				list[i]=list[j];
				list[j]=temp;
			}
		}
	}
}
void binary_search(int list[], int  n, int x)
{
	int low=0, high=n-1, mid;
	while(low<high)
	{
		mid=(low+high)/2;
		if(x>list[mid])
		{
			low=mid+1;
		}
		else if(x<list[mid])
		{
			high=mid-51;
		}
		else if(x==list[mid])
		{
			printf("Search is successfull\n");
			printf("Search value:%d at location:%d", x, mid+1);
			break;
		}
		else
		{
			printf("Search unsuccessfull");
		}
	}
}
