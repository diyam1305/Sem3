#include<stdio.h>
#include<stdlib.h>
void CqEnqueue(int [],int,int);
void CqDequeue(int [],int,int);
void display(int [],int);
int front=-1,rear=-1;
void main()
{
	int choice,n,q[100],x;
	 printf("Enter the size of Queue:");
   	scanf("%d",&n);
	do{
		printf("Press 1 for CqEnqueue operation\n");
		printf("Press 2 for CqDequeue operation\n");
		printf("Press 3 for Display operation\n");
		printf("Press 0 for exit\n");
		scanf("%d",&choice);
		
		switch(choice){
			case 1:
				printf("Enter value:\n");
				scanf("%d",&x);
				CqEnqueue(q,x,n);
				printf("CqEnqueue Opreation\n");
				break;
				
			case 2:
				CqDequeue(q,x,n);
				printf("CqDequeue Opreation\n");
				break;
				
			case 3:
				printf("Display Operation:\n");
				display(q,n);
				break;
				
			case 0:
				exit(0);
				break;
				
			default:
				printf("Enter invalid choice\n");
		}
	}while(1);
}
void CqEnqueue(int q[],int x,int n)
{
	printf("Circular queue front=%d and rear=%d\n",front,rear);
	if(front==0 && rear==n-1)
	{
		printf("Circular queue is overflow\n");
	}
	else
	{
		if(front==-1 && rear==-1)
		{
			front=rear=0;
		}
		else if(front!=0 && rear==n-1)
		{
			rear=0;
		}
		else
		{
			rear=rear+1;
		}
		q[rear]=x;
	}	
}
void CqDequeue(int q[],int x,int n)
{
	printf("Circular queue front=%d and rear=%d\n",front,rear);
	if(front==-1)
	{
		printf("Circular queue is underflow\n");
	}
	else
	
	{
		x=q[front];
		printf("Popped element is:%d\n",x);
		if(front==rear)
		{
			front=rear=-1;
		}
		else if (front==n-1)
		{
			front=0;
		}
		else
		{
			front=front+1;
		}
	}
}
void display(int q[],int n)
{
	int i;
	printf("Circular queue front=%d and rear=%d\n",front,rear);
	if(front==-1)
	{
	 	printf("Circular queue is empty\n");
    }
	else
	{
		if(rear<front)
		{
		 	for(i=front;i<n;i++)
		    {
		 		printf("%d\n",q[i]);
			}	
			for(i=0; i<=rear;i++)
			{
				printf("%d\n",q[i]);
			}
		}
		else
		{
			for(i=front; i<=rear; i++)
			{
				printf("%d\n",q[i]);
			}
		}
	}
}
