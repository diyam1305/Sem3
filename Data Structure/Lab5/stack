#include<stdio.h>
#include<stdlib.h>

int push(int[], int, int, int);
int pop(int[], int, int);
void peep(int[], int, int, int);
void change(int[], int, int, int, int);
void display(int[], int, int);

void main()
{
	int choice, x, a[100], n, top = -1, i;
	printf("Enter capacity of stack:");
	scanf("%d", &n);
	
	do
	{
		printf("Press 1 for Push Operation\n");
		printf("Press 2 for Pop Operation\n");
		printf("Press 3 for Peep Operation\n");
		printf("Press 4 for Change Operation\n");
		printf("Press 5 for Display Operation\n");
		printf("Press 0 for Exit\n\n");
		
		scanf("%d", &choice);
		switch(choice)
		{
			case 1:
				printf("Push Operation \n");
				printf("Enter value to be pushed:\n");
				scanf("%d", &x);
				top = push(a, top, x, n);
				break;
				
			case 2:
				printf("Pop Operation\n");
				top = pop(a, top, n);
				break;
				
			case 3:
				printf("Peep Operation\n");
				printf("Enter index:");
				scanf("%d", &i);
				peep(a, top, i, n);
				break;
				
			case 4:
				printf("Change Operation\n");
				printf("Enter index:");
				scanf("%d", &i);
				printf("Enter new value:");
				scanf("%d", &x);
				change(a, top, n, i, x);
				break;
				
			case 5:
				printf("Display Operation\n");
				display(a, top, n);
				break;
				
			case 0:
				 exit(0);
				break;
				
			default:
				printf("Enter valid choice");
		}
	}
	while(1);
}

int push(int a[], int top, int x, int n)
{
	printf("Push function top = %d \n", top);
	if(top >= n-1)
	{
		printf("Stack is overflow\n");
	}
	else
	{
		top = top + 1;
		a[top] = x;
	}
	return top;
}

int pop(int a[], int top, int n)
{
	int value;
	printf("Pop function top = %d \n", top);
	if(top == -1)
	{
		printf("Stack is underflow\n");
	}
	else
	{
		value = a[top];
		top = top - 1;
		printf("Value poped is:%d\n", value);
	}
	return top;
}

void peep(int a[], int top, int i, int n)
{
	int temp;
	printf("Peep function top = %d \n", top);
	if(top ==- 1)
	{
		printf("Stack is empty \n");
	}
	else
	{
		if(top - i + 1 < 0)
		{
			printf("Stack is underflow\n");
		}
		else
		{
			temp = a[top - i + 1];
			printf("ith element is:%d \n", temp);
		}
	}
}

void change(int a[], int top, int n, int i, int x)
{
	int temp;
	printf("Change function top = %d \n", top);
	if(top ==- 1)
	{
		printf("Stack is empty \n");
	}
	else
	{
		if(top - i + 1 < 0)
		{
			printf("Stack is underflow\n");
		}
		else
		{
			a[top - i + 1] = x;
			printf("ith element is:%d\n", temp);
		}
	}
}

void display(int a[], int top, int n)
{
	printf("Display function top = %d \n", top);
	if(top ==- 1)
	{
		printf("Stack is empty \n");
	}
	else
	{
		while(top >= 0)
		{
			printf("Display element is:%d\n", a[top]);
			top = top - 1;
		}
	}
}
