#include<stdio.h>
void bubble_sort(int[], int);
void main()
{
	int n, a[100], i;
	printf("Enter value of n:");
	scanf("%d", &n);
	printf("Enter elements:");
	for(i=0; i<n; i++)
	{
		scanf("%d",&a[i]);
	}
	bubble_sort(a,n);
	printf("Array after sorting:");
	for(i=0; i<n; i++)
	{
		printf("%d\n", a[i]);
	}
}
void bubble_sort(int a[100], int n)
{
	int i, j, temp=0, pass=1;
	while(pass<=n-1)
	{
		for(j=0; j<n-pass; j++)
		{
			if(a[j]>a[j+1])
			{
				temp=a[j];
				a[j]=a[j+1];
				a[j+1]=temp;
			}
		}
		pass=pass+1;
	}
}
